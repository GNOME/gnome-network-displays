msgstr "A estabelecer ligação ao destino (sink)"

#: src/app/nd-window.c:260
msgid "Starting to stream"
msgstr "A iniciar transmissão"

#: src/nd-window.ui:6
msgid "Network Displays"
msgstr "Ecrãs de Rede"

#: src/nd-window.ui:28
msgid "No Wi‑Fi P2P Adapter Found"
msgstr "Nenhum adaptador Wi-Fi P2P encontrado"

#: src/nd-window.ui:29
msgid ""
"No usable wireless adapters were found. Please verify that Wi‑Fi is enabled "
"and Wi‑Fi P2P operations are available in both NetworkManager and "
"wpa_supplicant."
msgstr ""
"Não foram encontrados adaptadores sem fios utilizáveis. Verifique se o Wi-Fi "
"está ativado e se as operações Wi-Fi P2P estão disponíveis tanto no "
"NetworkManager como no wpa_supplicant."

#: src/nd-window.ui:63
msgid "Available Video Sinks"
msgstr "Destinos de vídeo (sinks) disponíveis"

